# =============================================================================
# RENDER WEB SERVICE — Environment (copy keys into Render → Environment)
# =============================================================================
# Required for production API:
#
#   DATABASE_URL     = On Render Web Service: Internal Database URL (host like dpg-xxx-a, port 5432).
#                      On your PC / CI: External URL (*.region-postgres.render.com) + ?sslmode=require
#   JWT_SECRET       = Long random secret (e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#   FOOTBALL_API_KEY = From https://dashboard.api-football.com
#
# Recommended:
#
#   NODE_ENV         = production
#   API_FOOTBALL_HOST = v3.football.api-sports.io
#
# Do NOT set on backend Render: Cloudinary / NEXT_PUBLIC_* (frontend uploads; API not used).
#
# Optional (defaults exist in code):
#   ODDS_SYNC_BATCH
#   ODDS_FETCH_CONCURRENCY   # parallel fixture odds fetches per 30s tick (default 8, max 20)
#   FIXTURE_WINDOW_DAYS        # rolling days: sync, purge, default /fixtures filter (default 7, max 30)
#   FIXTURE_LIST_ALL_IN_DB     # 1/true: /fixtures skips date window (up to 3000 rows; bulk migrate)
#   BOOTSTRAP_ON_EMPTY_FIXTURES # 0/false/no: disable auto API sync when /fixtures returns 0 rows (default: enabled)
#   FOOTBALL_CURRENT_SEASON
#   BOOTSTRAP_FIXTURES_BY_DATE
#   BOOTSTRAP_ODDS_BY_DATE
#   ROLLING_FIXTURE_REFRESH     # 0/false/no: disable extra cron (every 6h) that re-syncs fixtures-by-date + purge outside window
#   DB_CONNECTION_TIMEOUT_MS
#
# One-off admin user (run locally / CI, NOT as long-lived Render env):
#   SET_ADMIN_PHONE + SET_ADMIN_PASSWORD  →  npm run admin:set
#
# One-off bulk copy local football data → Render: SOURCE_DATABASE_URL + DATABASE_URL + MIGRATE_FOOTBALL_CONFIRM=yes → npm run migrate:football (see README)
# =============================================================================

# =========================
# SERVER
# =========================
PORT=4000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-for-tipico

# =========================
# POSTGRES
# Render (API on Render): Internal Database URL. Local PC → DB: External URL.
# Include ?sslmode=require when your provider needs TLS.
# =========================
DATABASE_URL=postgresql://USER:PASSWORD@HOST.region-postgres.render.com/DATABASE_NAME?sslmode=require

# Optional: only if you do NOT use DATABASE_URL (e.g. local Postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SCHEMA=public
# DB_CONNECTION_TIMEOUT_MS=15000
# DATABASE_SSL=true

# =========================
# API-FOOTBALL (v3)
# https://dashboard.api-football.com
# =========================
API_FOOTBALL_HOST=v3.football.api-sports.io
FOOTBALL_API_KEY=YOUR_API_FOOTBALL_KEY_HERE

# ODDS_SYNC_BATCH=120
# FOOTBALL_CURRENT_SEASON=2025
# BOOTSTRAP_FIXTURES_BY_DATE=1
# BOOTSTRAP_ODDS_BY_DATE=1

# =========================
# FRONTEND ONLY (Vercel / .env.local) — not read by backend/src
# =========================
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
