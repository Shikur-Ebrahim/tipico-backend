{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:setup": "ts-node-dev --transpile-only src/db/setup.ts",
    "db:init": "ts-node-dev --transpile-only src/db/init.ts",
    "sync:status": "ts-node-dev --transpile-only src/scripts/sync.ts status",
    "sync:bootstrap": "ts-node-dev --transpile-only src/scripts/sync.ts bootstrap",
    "sync:live": "ts-node-dev --transpile-only src/scripts/sync.ts live",
    "sync:odds": "ts-node-dev --transpile-only src/scripts/sync.ts odds",
    "sync:fill-week": "ts-node-dev --transpile-only src/scripts/syncFillWeek.ts",
    "lint": "eslint src/",
    "db:verify-remote": "node scripts/verify-render-tables.js",
